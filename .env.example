# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/syncsenta
REDIS_URL=redis://127.0.0.1:6379

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=8080

# ─── Blockchain (Polygon) ────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/your-api-key
POLYGON_PRIVATE_KEY=0x...
POLYGON_CHAIN_ID=80001
CREDENTIALS_CONTRACT_ADDRESS=0x...
TOKEN_CONTRACT_ADDRESS=0x...
APPROVAL_REGISTRY_ADDRESS=0x...
CONTENT_REGISTRY_ADDRESS=0x...

# ─── IPFS (Decentralized Storage) ────────────────────────────────────────────
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/
PINATA_API_KEY=...
PINATA_SECRET_KEY=...

# ─── DID (Self-Sovereign Identity) ───────────────────────────────────────────
DID_METHOD=key
DID_RESOLVER_URL=https://dev.uniresolver.io/1.0/identifiers/

# ─── AI Services ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Multiple Groq accounts for high availability (750 requests/day each)
GROQ_API_KEY_1=gsk_your_first_groq_key_here
GROQ_API_KEY_2=gsk_your_second_groq_key_here
GROQ_API_KEY_3=gsk_your_third_groq_key_here
GROQ_API_KEY_4=gsk_your_fourth_groq_key_here

# AISA.one API for multi-model access ($20 free credits)
AISA_API_KEY=sk_your_aisa_api_key_here
AISA_BASE_URL=https://api.aisa.one/v1

ELEVENLABS_API_KEY=...

# ─── AMD Developer Cloud ─────────────────────────────────────────────────────
AMD_API_KEY=your_amd_api_key_here
AMD_PROJECT_ID=your_project_id_here
AMD_REGION=us-east-1
AMD_INSTANCE_TYPE=mi300x

# ─── Hugging Face ────────────────────────────────────────────────────────────
HF_TOKEN=hf_your_huggingface_token_here
HF_HUB_CACHE=/tmp/huggingface_cache
HF_DATASETS_CACHE=/tmp/huggingface_datasets

# ─── M-Pesa (Daraja API) ─────────────────────────────────────────────────────
MPESA_CONSUMER_KEY=...
MPESA_CONSUMER_SECRET=...
MPESA_SHORTCODE=174379
MPESA_PASSKEY=...
MPESA_CALLBACK_URL=https://yourdomain.com/api/v1/payments/mpesa/callback

# ─── Africa's Talking (SMS) ──────────────────────────────────────────────────
AT_API_KEY=...
AT_USERNAME=sandbox

# ─── Jitsi Meet ──────────────────────────────────────────────────────────────
JITSI_SECRET=your-jitsi-jwt-secret
JITSI_DOMAIN=meet.jit.si

# ─── Storage ─────────────────────────────────────────────────────────────────
STORAGE_BUCKET=syncsenta-content

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si
